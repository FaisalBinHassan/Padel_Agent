# ── Push notifications via ntfy.sh (free, no account needed) ──────────────────
# 1. Install the ntfy app on your phone: https://ntfy.sh/
# 2. Subscribe to a topic (make it unique, e.g. padel-yourname-2026)
# 3. Set the same topic below
NTFY_TOPIC=padel-yourname-2026

# Optional: self-hosted ntfy server
# NTFY_SERVER=https://ntfy.sh

# ── Polling interval (seconds) ────────────────────────────────────────────────
# Default: 300 (5 minutes). Set lower for faster alerts, higher to be polite.
CHECK_INTERVAL=300
